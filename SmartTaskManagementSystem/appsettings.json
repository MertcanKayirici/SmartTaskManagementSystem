{
  // Database connection configuration
  "ConnectionStrings": {
    // Default connection used by Entity Framework Core and Identity
    // Server=.;                  -> Local SQL Server instance
    // Database=SmartTaskManagementDb -> Database name
    // Trusted_Connection=True   -> Uses Windows Authentication
    // TrustServerCertificate=True -> Bypasses SSL certificate validation (useful for local dev)
    // MultipleActiveResultSets=true -> Allows multiple queries to run simultaneously
    "DefaultConnection": "Server=.;Database=SmartTaskManagementDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },

  // Application logging configuration
  "Logging": {
    "LogLevel": {
      // Default log level for the entire application
      "Default": "Information",

      // Reduce noise from ASP.NET Core internal logs
      "Microsoft.AspNetCore": "Warning"
    }
  },

  // Defines which hosts are allowed to access the application
  // "*" means all hosts are allowed (suitable for development)
  "AllowedHosts": "*"
}