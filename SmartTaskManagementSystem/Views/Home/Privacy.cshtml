@{
    // Sets the page title for the privacy policy view
    ViewData["Title"] = "Privacy Policy";
}

<style>
    /* Main layout container for the privacy page */
    .privacy-page {
        max-width: 900px;
        margin: 0 auto;
    }

    /* Main card styling for privacy content */
    .privacy-card {
        background: linear-gradient(180deg, #ffffff 0%, #f8faff 100%);
        border: 1px solid #eef1f6;
        border-radius: 24px;
        box-shadow: 0 12px 28px rgba(15, 23, 42, 0.05);
    }

    /* Shared spacing for privacy content sections */
    .privacy-section {
        margin-bottom: 2rem;
    }

        /* Section heading styling */
        .privacy-section h5 {
            font-weight: 700;
            margin-bottom: 10px;
        }

        /* Section paragraph styling */
        .privacy-section p {
            color: #6b7280;
            line-height: 1.7;
            margin-bottom: 0;
        }

    /* Inline badge styling for trust/security labels */
    .privacy-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #f8fafc;
        border: 1px solid #e5e7eb;
        border-radius: 999px;
        padding: 6px 14px;
        font-size: 0.8rem;
        font-weight: 600;
        color: #374151;
    }
</style>

<div class="container py-5 privacy-page">

    <!-- Page header -->
    <div class="text-center mb-5">
        <h1 class="fw-bold">Privacy Policy</h1>
        <p class="text-muted">
            Smart Task Management System protects your data and ensures secure usage.
        </p>
    </div>

    <!-- Main privacy content card -->
    <div class="privacy-card p-4 p-md-5">

        <!-- Overview section -->
        <div class="privacy-section">
            <h5>Overview</h5>
            <p>
                This application is designed to help users manage tasks efficiently.
                We prioritize data privacy, user control, and secure access to ensure
                a safe and reliable experience.
            </p>
        </div>

        <!-- Data collection section -->
        <div class="privacy-section">
            <h5>Data Collection</h5>
            <p>
                The system only stores the information required for functionality,
                such as user accounts, tasks, and categories. No unnecessary personal
                data is collected or shared.
            </p>
        </div>

        <!-- Security section -->
        <div class="privacy-section">
            <h5>Security</h5>
            <p>
                Authentication is handled securely using built-in identity mechanisms.
                Each user's data is isolated and protected from unauthorized access.
            </p>
        </div>

        <!-- Data usage section -->
        <div class="privacy-section">
            <h5>Data Usage</h5>
            <p>
                All stored data is used solely for providing core application features,
                including task management, tracking progress, and generating insights.
            </p>
        </div>

        <!-- User control section -->
        <div class="privacy-section">
            <h5>User Control</h5>
            <p>
                Users have full control over their data. They can create, update, or delete
                their tasks and categories at any time within the system.
            </p>
        </div>

        <!-- Trust and security badges -->
        <div class="d-flex flex-wrap gap-2 mt-4">
            <span class="privacy-badge"><i class="bi bi-shield-check"></i> Secure Authentication</span>
            <span class="privacy-badge"><i class="bi bi-lock"></i> Data Protection</span>
            <span class="privacy-badge"><i class="bi bi-person-check"></i> User-Based Access</span>
        </div>

    </div>

</div>