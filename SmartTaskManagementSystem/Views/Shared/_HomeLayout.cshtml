<!DOCTYPE html>
<html lang="en">
<head>
    <!-- Basic meta configuration -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Dynamic page title -->
    <title>@ViewData["Title"] - SmartTaskManagementSystem</title>

    <!-- Core styles -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SmartTaskManagementSystem.styles.css" asp-append-version="true" />

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        /* Global page background and base typography */
        body {
            min-height: 100vh;
            background: radial-gradient(circle at top left, rgba(111, 66, 193, 0.12), transparent 30%),
                        radial-gradient(circle at top right, rgba(13, 110, 253, 0.10), transparent 25%),
                        linear-gradient(180deg, #f8f9ff 0%, #f5f7fb 100%);
            color: #1f2937;
        }

        /* Main navigation bar container */
        .main-navbar {
            background: rgba(255, 255, 255, 0.78);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border: 1px solid rgba(255, 255, 255, 0.45);
            box-shadow: 0 10px 30px rgba(31, 41, 55, 0.08);
            border-radius: 22px;
            margin: 18px auto 0 auto;
            max-width: 1320px;
        }

        /* Brand (logo + title) styling */
        .navbar-brand.smart-brand {
            font-size: 1.25rem;
            font-weight: 800;
            letter-spacing: 0.2px;
            color: #111827 !important;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* Brand icon badge */
        .brand-badge {
            width: 42px;
            height: 42px;
            border-radius: 14px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #6f42c1, #0d6efd);
            color: white;
            font-weight: 800;
            box-shadow: 0 8px 18px rgba(111, 66, 193, 0.25);
        }

        /* Navigation link styling */
        .navbar-nav .nav-link.smart-link {
            color: #374151 !important;
            font-weight: 600;
            border-radius: 12px;
            padding: 10px 16px !important;
            transition: all 0.25s ease;
        }

        /* Navigation hover effect */
        .navbar-nav .nav-link.smart-link:hover {
            background: rgba(13, 110, 253, 0.08);
            color: #0d6efd !important;
            transform: translateY(-1px);
        }

        /* Navigation group spacing */
        .smart-nav-group {
            gap: 4px;
        }

        /* Auth button container (Login/Register) */
        .home-auth-actions {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        /* Login button */
        .home-login-btn {
            color: #2563eb;
            text-decoration: none;
            font-weight: 700;
            padding: 10px 14px;
            transition: all 0.2s ease;
        }

        .home-login-btn:hover {
            color: #1d4ed8;
        }

        /* Register button (primary CTA) */
        .home-register-btn {
            min-width: 130px;
            min-height: 50px;
            border-radius: 999px;
            background: linear-gradient(135deg, #2563eb, #3b82f6);
            color: #fff;
            text-decoration: none;
            font-weight: 800;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0 22px;
            box-shadow: 0 10px 22px rgba(37, 99, 235, 0.20);
            transition: all 0.2s ease;
        }

        .home-register-btn:hover {
            transform: translateY(-1px);
            color: #fff;
        }

        /* Page wrapper */
        .page-shell {
            padding-top: 24px;
            padding-bottom: 40px;
        }

        /* Hero section (highlight banner) */
        .hero-strip {
            max-width: 1320px;
            margin: 18px auto 24px auto;
            background: linear-gradient(135deg, rgba(111, 66, 193, 0.95), rgba(13, 110, 253, 0.92));
            border-radius: 28px;
            padding: 28px 32px;
            color: white;
            box-shadow: 0 18px 50px rgba(79, 70, 229, 0.18);
            position: relative;
            overflow: hidden;
        }

        /* Decorative top-right element */
        .hero-strip::before {
            content: "";
            position: absolute;
            width: 220px;
            height: 220px;
            border-radius: 999px;
            background: rgba(255,255,255,0.10);
            top: -60px;
            right: -40px;
        }

        /* Decorative bottom-left element */
        .hero-strip::after {
            content: "";
            position: absolute;
            width: 160px;
            height: 160px;
            border-radius: 999px;
            background: rgba(255,255,255,0.08);
            bottom: -60px;
            left: -20px;
        }

        /* Hero title */
        .hero-strip h1 {
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 8px;
            position: relative;
            z-index: 1;
        }

        /* Hero description */
        .hero-strip p {
            margin-bottom: 0;
            color: rgba(255,255,255,0.88);
            position: relative;
            z-index: 1;
            max-width: 760px;
        }

        /* Content container */
        .content-wrapper {
            max-width: 1320px;
            margin: 0 auto;
        }

        /* Footer container */
        .smart-footer {
            max-width: 1320px;
            margin: 24px auto 20px auto;
            padding: 18px 24px;
            border-radius: 20px;
            background: rgba(255,255,255,0.72);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.45);
            box-shadow: 0 10px 24px rgba(15, 23, 42, 0.05);
        }
    </style>
</head>

<body>

    <!-- MAIN NAVIGATION BAR -->
    <header>
        <nav class="navbar navbar-expand-lg main-navbar px-3 px-lg-4 py-3">
            <div class="container-fluid px-0">

                <!-- Brand / Logo -->
                <a class="navbar-brand smart-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="brand-badge">ST</span>
                    <span>Smart Task Management</span>
                </a>

                <!-- Mobile menu toggle -->
                <button class="navbar-toggler shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <i class="bi bi-list fs-4"></i>
                </button>

                <!-- Navigation links -->
                <div class="collapse navbar-collapse mt-3 mt-lg-0" id="mainNavbar">
                    <ul class="navbar-nav smart-nav-group me-auto mb-2 mb-lg-0 ms-lg-4">
                        <li class="nav-item">
                            <a class="nav-link smart-link" href="#features">Features</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link smart-link" href="#how-it-works">How It Works</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link smart-link" href="#cta">Get Started</a>
                        </li>
                    </ul>

                    <!-- Authentication actions -->
                    <div class="home-auth-actions">
                        <a class="home-login-btn" asp-area="Identity" asp-page="/Account/Login">
                            Login
                        </a>
                        <a class="home-register-btn" asp-area="Identity" asp-page="/Account/Register">
                            Register
                        </a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <!-- PAGE CONTENT WRAPPER -->
    <div class="page-shell">

        <!-- HERO SECTION -->
        <section class="hero-strip">
            <h1>Organize your workflow beautifully</h1>
            <p>
                Manage tasks, categories, progress, and productivity in a clean and modern workspace.
            </p>
        </section>

        <!-- MAIN CONTENT -->
        <div class="content-wrapper">
            <main role="main">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- FOOTER -->
    <footer class="smart-footer text-muted">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-2">
            <div>
                &copy; @DateTime.Now.Year - <strong>SmartTaskManagementSystem</strong>
            </div>

            <!-- Footer navigation links -->
            <div class="d-flex gap-3 flex-wrap">
                <a class="nav-link" href="#features">Features</a>
                <a class="nav-link" href="#how-it-works">How It Works</a>
                <a class="nav-link" href="#cta">Get Started</a>
            </div>
        </div>
    </footer>

    <!-- Core scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Page-specific scripts -->
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>