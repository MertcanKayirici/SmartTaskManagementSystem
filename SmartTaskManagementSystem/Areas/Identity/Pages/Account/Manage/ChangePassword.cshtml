@page
@using SmartTaskManagementSystem.Areas.Identity.Pages.Account.Manage
@model SmartTaskManagementSystem.Areas.Identity.Pages.Account.Manage.ChangePasswordModel

@{
    // Page title shown in browser tab
    ViewData["Title"] = "Change Password";

    // Sets the active navigation item in sidebar
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<style>
    /* Main grid layout: sidebar + content */
    .manage-page-grid {
        display: grid;
        grid-template-columns: 320px 1fr;
        gap: 24px;
        align-items: start;
    }

    /* Card components (sidebar + main content) */
    .manage-side-card,
    .manage-main-card {
        background: linear-gradient(180deg, #ffffff 0%, #f8faff 100%);
        border: 1px solid #eef1f6;
        border-radius: 28px;
        box-shadow: 0 18px 42px rgba(15, 23, 42, 0.07);
    }

    /* Sidebar card (sticky for desktop view) */
    .manage-side-card {
        padding: 28px 24px;
        position: sticky;
        top: 24px;
    }

    /* Main content card */
    .manage-main-card {
        padding: 32px;
    }

    /* Icon container */
    .manage-icon-box {
        width: 64px;
        height: 64px;
        border-radius: 20px;
        background: linear-gradient(135deg, #6f42c1 0%, #0d6efd 100%);
        color: #fff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.45rem;
        box-shadow: 0 14px 30px rgba(13, 110, 253, 0.20);
        margin-bottom: 18px;
    }

    /* Card title */
    .manage-card-title {
        font-size: 1.7rem;
        font-weight: 800;
        color: #111827;
        margin-bottom: 8px;
    }

    /* Informational text */
    .manage-note {
        color: #6b7280;
        margin-bottom: 0;
        line-height: 1.7;
    }

    /* Sidebar info list */
    .manage-side-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-top: 24px;
    }

    /* Sidebar item */
    .manage-side-item {
        display: flex;
        gap: 10px;
        align-items: flex-start;
        padding: 12px 14px;
        border-radius: 16px;
        background: #fff;
        border: 1px solid #eef1f6;
        color: #4b5563;
        font-size: 0.95rem;
    }

    /* Top information strip */
    .manage-top-strip {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        padding: 16px 18px;
        border: 1px solid #eef1f6;
        border-radius: 18px;
        background: #ffffff;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }

    /* Label text */
    .manage-info-label {
        font-size: 0.85rem;
        color: #6b7280;
        margin-bottom: 4px;
    }

    /* Value text */
    .manage-info-value {
        font-weight: 700;
        color: #111827;
        word-break: break-word;
    }

    /* Badge styling */
    .manage-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        border-radius: 999px;
        background: #eef2ff;
        color: #4338ca;
        border: 1px solid #e0e7ff;
        font-size: 0.85rem;
        font-weight: 700;
        white-space: nowrap;
    }

    /* Input styling */
    .form-floating > .form-control {
        border-radius: 18px;
        border: 1px solid #e5e7eb;
        min-height: 58px;
        box-shadow: none !important;
        background-color: #fff !important;
    }

        /* Input focus state */
        .form-floating > .form-control:focus {
            border-color: #0d6efd;
        }

    /* Submit button */
    .manage-btn {
        min-height: 54px;
        border-radius: 16px;
        font-weight: 700;
        font-size: 1rem;
        transition: all 0.2s ease;
        box-shadow: 0 12px 28px rgba(15, 23, 42, 0.08);
    }

        .manage-btn:hover {
            transform: translateY(-1px);
        }

    /* Helper info box */
    .manage-helper-box {
        margin-top: 22px;
        padding: 18px 20px;
        border-radius: 18px;
        background: linear-gradient(180deg, #ffffff 0%, #f8faff 100%);
        border: 1px solid #eef1f6;
    }

    .manage-helper-title {
        font-weight: 700;
        color: #111827;
        margin-bottom: 6px;
    }

    .manage-helper-text {
        color: #6b7280;
        margin-bottom: 0;
        line-height: 1.65;
        font-size: 0.95rem;
    }

    /* Validation styles */
    .validation-summary-valid {
        display: none;
    }

    .field-validation-error {
        display: block;
        margin-top: 6px;
    }

    /* Responsive adjustments */
    @@media (max-width: 991.98px) {
        .manage-page-grid {
            grid-template-columns: 1fr;
        }

        .manage-side-card {
            position: static;
        }
    }

    @@media (max-width: 576px) {
        .manage-main-card,
        .manage-side-card {
            padding: 22px 18px;
            border-radius: 22px;
        }

        .manage-card-title {
            font-size: 1.4rem;
        }

        .manage-icon-box {
            width: 56px;
            height: 56px;
            border-radius: 18px;
            font-size: 1.25rem;
        }
    }
</style>

<!-- Displays status message (success/error) -->
<partial name="_StatusMessage" for="StatusMessage" />

<div class="manage-page-grid">

    <!-- SIDEBAR: Security info and tips -->
    <div class="manage-side-card">
        <div class="manage-icon-box">
            <i class="bi bi-shield-lock"></i>
        </div>

        <h2 class="manage-card-title">Change Password</h2>
        <p class="manage-note">
            You can improve your account security by choosing a strong new password.
        </p>

        <!-- Security tips list -->
        <div class="manage-side-list">
            <div class="manage-side-item">
                <i class="bi bi-check-circle text-success"></i>
                <span>A new password makes your account more secure.</span>
            </div>
            <div class="manage-side-item">
                <i class="bi bi-key text-primary"></i>
                <span>It is better to use letters, numbers, and symbols.</span>
            </div>
            <div class="manage-side-item">
                <i class="bi bi-shield-check text-warning"></i>
                <span>It is recommended to choose a strong password different from your old one.</span>
            </div>
        </div>
    </div>

    <!-- MAIN CONTENT: Password change form -->
    <div class="manage-main-card">

        <!-- Info strip -->
        <div class="manage-top-strip">
            <div>
                <div class="manage-info-label">Security update</div>
                <div class="manage-info-value">Keep your account protected with a stronger password.</div>
            </div>

            <div class="manage-badge">
                <i class="bi bi-shield-check"></i>
                Security
            </div>
        </div>

        <!-- Change password form -->
        <form id="change-password-form" method="post" novalidate>

            <!-- Validation summary -->
            <div asp-validation-summary="ModelOnly"
                 class="alert alert-danger rounded-4 border-0 shadow-sm mb-4"></div>

            <!-- Current password -->
            <div class="form-floating mb-3">
                <input asp-for="Input.OldPassword" class="form-control" placeholder="Current password" />
                <label asp-for="Input.OldPassword">Current Password</label>
                <span asp-validation-for="Input.OldPassword" class="text-danger small"></span>
            </div>

            <!-- New password -->
            <div class="form-floating mb-3">
                <input asp-for="Input.NewPassword" class="form-control" placeholder="New password" />
                <label asp-for="Input.NewPassword">New Password</label>
                <span asp-validation-for="Input.NewPassword" class="text-danger small"></span>
            </div>

            <!-- Confirm new password -->
            <div class="form-floating mb-3">
                <input asp-for="Input.ConfirmPassword" class="form-control" placeholder="Confirm password" />
                <label asp-for="Input.ConfirmPassword">Confirm New Password</label>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
            </div>

            <!-- Submit button -->
            <button type="submit" class="btn btn-dark manage-btn w-100">
                Update Password
            </button>
        </form>

        <!-- Helper tip -->
        <div class="manage-helper-box">
            <div class="manage-helper-title">Password tip</div>
            <p class="manage-helper-text">
                Using a long and hard-to-guess password is better for security.
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Client-side validation scripts -->
    <partial name="_ValidationScriptsPartial" />
}