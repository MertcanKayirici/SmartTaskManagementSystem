@page
@model SmartTaskManagementSystem.Areas.Identity.Pages.Account.RegisterModel

@{
    // Page title displayed in browser tab
    ViewData["Title"] = "Register";

    // Custom authentication layout for register page
    Layout = "/Views/Shared/_AuthLayout.cshtml";
}

<style>
    /* Main container for authentication pages */
    .auth-page {
        min-height: calc(100vh - 120px);
        display: flex;
        align-items: center;
    }

    /* Outer wrapper with rounded corners and shadow */
    .auth-shell {
        border-radius: 28px;
        overflow: hidden;
        background: #fff;
        box-shadow: 0 24px 60px rgba(15, 23, 42, 0.10);
    }

    /* Left branding panel with gradient background */
    .auth-brand-panel {
        background: linear-gradient(135deg, #6f42c1 0%, #0d6efd 55%, #20c997 100%);
        color: #fff;
        position: relative;
        overflow: hidden;
        min-height: 100%;
    }

        /* Decorative background elements */
        .auth-brand-panel::before,
        .auth-brand-panel::after {
            content: "";
            position: absolute;
            border-radius: 50%;
            background: rgba(255,255,255,0.10);
        }

        .auth-brand-panel::before {
            width: 180px;
            height: 180px;
            top: -40px;
            right: -30px;
        }

        .auth-brand-panel::after {
            width: 120px;
            height: 120px;
            bottom: -25px;
            left: -20px;
        }

    /* Branding content wrapper */
    .auth-brand-content {
        position: relative;
        z-index: 1;
    }

    /* Logo styling */
    .auth-logo {
        width: 54px;
        height: 54px;
        border-radius: 18px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,0.18);
        backdrop-filter: blur(6px);
        font-weight: 700;
        font-size: 1.2rem;
        margin-bottom: 1rem;
    }

    /* Feature list container */
    .auth-feature-list {
        display: flex;
        flex-direction: column;
        gap: 14px;
        margin-top: 2rem;
    }

    /* Individual feature card */
    .auth-feature-item {
        background: rgba(255,255,255,0.12);
        border: 1px solid rgba(255,255,255,0.16);
        border-radius: 18px;
        padding: 14px 16px;
    }

    /* Right side form panel */
    .auth-form-panel {
        background: linear-gradient(180deg, #ffffff 0%, #f8faff 100%);
    }

    /* Wrapper for form content */
    .auth-form-wrap {
        max-width: 460px;
        margin: 0 auto;
    }

    /* Page title */
    .auth-title {
        font-weight: 700;
        color: #1f2937;
    }

    /* Subtitle text */
    .auth-subtitle {
        color: #6b7280;
    }

    /* Input field styling */
    .form-floating > .form-control {
        border-radius: 16px;
        border: 1px solid #e5e7eb;
        min-height: 58px;
        box-shadow: none !important;
        background-color: #fff !important;
    }

        /* Focus state for inputs */
        .form-floating > .form-control:focus {
            border-color: #0d6efd;
        }

    /* Fix autofill styling issues in browsers */
    .form-control:-webkit-autofill,
    .form-control:-webkit-autofill:hover,
    .form-control:-webkit-autofill:focus,
    .form-control:-webkit-autofill:active {
        -webkit-box-shadow: 0 0 0 1000px #ffffff inset !important;
        -webkit-text-fill-color: #1f2937 !important;
        transition: background-color 5000s ease-in-out 0s;
        border-radius: 16px;
    }

    /* Submit button styling */
    .auth-btn {
        min-height: 54px;
        border-radius: 16px;
        font-weight: 600;
        font-size: 1rem;
    }

    /* Navigation links under form */
    .auth-links {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

        .auth-links a {
            text-decoration: none;
        }

            .auth-links a:hover {
                text-decoration: underline;
            }

    /* Validation styles */
    .validation-summary-valid {
        display: none;
    }

    .validation-summary-errors ul {
        margin-bottom: 0;
        padding-left: 1rem;
    }

    .field-validation-error {
        display: block;
        margin-top: 6px;
    }

    /* Responsive layout adjustments */
    @@media (max-width: 991.98px) {
        .auth-brand-panel {
            min-height: 280px;
        }

        .auth-form-wrap {
            max-width: 100%;
        }
    }
</style>

<div class="container auth-page py-5">
    <div class="row g-0 w-100 auth-shell">

        <!-- LEFT PANEL: Branding and feature highlights -->
        <div class="col-lg-5">
            <div class="auth-brand-panel h-100 p-4 p-lg-5 d-flex flex-column justify-content-center">
                <div class="auth-brand-content">

                    <!-- Application logo -->
                    <div class="auth-logo">ST</div>

                    <!-- Main heading -->
                    <h1 class="fw-bold mb-3">Create account</h1>
                    <p class="mb-0">
                        Join the workspace and manage your tasks, categories and productivity in one clean system.
                    </p>

                    <!-- Feature list -->
                    <div class="auth-feature-list">
                        <div class="auth-feature-item">
                            <div class="fw-semibold mb-1">Smart task tracking</div>
                            <div class="small">
                                Plan your work with deadlines, priorities and progress tracking.
                            </div>
                        </div>

                        <div class="auth-feature-item">
                            <div class="fw-semibold mb-1">Clean category management</div>
                            <div class="small">
                                Keep everything organized with clear and structured categories.
                            </div>
                        </div>

                        <div class="auth-feature-item">
                            <div class="fw-semibold mb-1">Insightful dashboard</div>
                            <div class="small">
                                Follow your task performance and productivity with a modern dashboard.
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- RIGHT PANEL: Registration form -->
        <div class="col-lg-7">
            <div class="auth-form-panel h-100 p-4 p-lg-5">
                <div class="auth-form-wrap">

                    <!-- Form header -->
                    <div class="mb-4">
                        <h2 class="auth-title mb-2">Register</h2>
                        <p class="auth-subtitle mb-0">
                            Create your account to get started.
                        </p>
                    </div>

                    <!-- Registration form -->
                    <form method="post" autocomplete="on">
                        @Html.AntiForgeryToken() <!-- CSRF protection -->
                        <!-- Validation summary -->
                        <div asp-validation-summary="ModelOnly"
                             class="alert alert-danger rounded-4 border-0 shadow-sm mb-4"
                             role="alert"></div>

                        <!-- Email input -->
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email"
                                   class="form-control"
                                   type="email"
                                   autocomplete="email username"
                                   placeholder="name@example.com" />
                            <label asp-for="Input.Email">Email</label>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <!-- Password input -->
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Password"
                                   class="form-control"
                                   type="password"
                                   autocomplete="new-password"
                                   placeholder="Password" />
                            <label asp-for="Input.Password">Password</label>
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>

                        <!-- Confirm password input -->
                        <div class="form-floating mb-3">
                            <input asp-for="Input.ConfirmPassword"
                                   class="form-control"
                                   type="password"
                                   autocomplete="new-password"
                                   placeholder="Confirm Password" />
                            <label asp-for="Input.ConfirmPassword">Confirm Password</label>
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <!-- Submit button -->
                        <button type="submit" class="w-100 btn btn-dark auth-btn">
                            Create Account
                        </button>

                        <!-- Redirect to login -->
                        <div class="auth-links mt-4">
                            <a asp-page="./Login">Already have an account? Log in</a>
                        </div>
                    </form>

                    <!-- Info card -->
                    <div class="auth-side-card p-4 mt-4">
                        <h5 class="fw-bold mb-2">Account benefits</h5>
                        <p class="text-muted mb-0">
                            After registering, you can manage your own tasks, categories and dashboard data securely inside your personal workspace.
                        </p>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Client-side validation scripts -->
    <partial name="_ValidationScriptsPartial" />
}